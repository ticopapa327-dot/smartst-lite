{
  "schemaVersion": "ust.desktop-client.config.v0.1",
  "role": "UST Desktop Client",
  "serverUrl": "http://<OR-PC-LAN-IP>:4780",
  "orAgentUrl": "http://127.0.0.1:4781",
  "defaultClientType": "or-windows",
  "livekit": {
    "publicUrlFromServer": true,
    "tokenSource": "UST Server",
    "storeApiSecret": false
  },
  "layout": {
    "defaultView": "workbench",
    "defaultChannelId": "field-camera",
    "allowMultiMonitorExpansion": true
  },
  "observer": {
    "showRoomCode": true,
    "showQrCode": true
  },
  "logs": {
    "logDirectory": "%APPDATA%\\视捷UST\\logs"
  }
}
