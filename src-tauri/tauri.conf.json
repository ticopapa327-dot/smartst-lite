{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UST Desktop Client",
  "version": "0.1.4",
  "identifier": "com.ust.lite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "npm run media-worker:native:build:release",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "视捷UST",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../native-worker/target/release/ust-native-worker.exe": "bin/ust-native-worker.exe"
    }
  }
}
